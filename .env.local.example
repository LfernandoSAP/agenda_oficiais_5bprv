# Supabase PostgreSQL
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth v5 (Auth.js)
AUTH_SECRET="gere-com: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Admin master inicial (usado SOMENTE pelo seed)
# Use apenas em ambiente local. Em produção, defina diretamente no Vercel
# (Settings -> Environment Variables) e rode o seed uma única vez.
ADMIN_INITIAL_CPF="00000000000"
ADMIN_INITIAL_PASSWORD="senha-forte-temporaria-trocar-no-primeiro-login"
